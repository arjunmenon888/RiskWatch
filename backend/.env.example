APP_NAME=RiskWatch API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://riskwatch:riskwatch@localhost:5432/riskwatch
BACKEND_CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
SECRET_KEY=change-this-in-development
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=
FRONTEND_URL=http://localhost:8081
PASSWORD_RESET_EXPIRE_MINUTES=30
EMAIL_DELIVERY_ENABLED=false
LOCAL_STORAGE_DIR=./storage
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=90
OPENAI_ALLOW_LOCAL_FALLBACK=true
